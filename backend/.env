# ── MLX LLM server ────────────────────────────────────────────────────────
# mlx_lm.server starts automatically when you run the backend.
# Models are downloaded from HuggingFace Hub on first run and cached at
# ~/.cache/huggingface/hub/ — subsequent starts are instant.
#
# Recommended models for M5 Pro / 48 GB:
#   mlx-community/Qwen2.5-32B-Instruct-4bit    ~18 GB  (default)
#   mlx-community/Qwen2.5-14B-Instruct-4bit    ~8 GB   (faster)
#   mlx-community/Mistral-Nemo-Instruct-4bit   ~7 GB   (lightest)
MLX_MODEL=mlx-community/Qwen2.5-32B-Instruct-4bit
MLX_SERVER_HOST=127.0.0.1
MLX_SERVER_PORT=8081
MLX_CONTEXT_LENGTH=8192

# ── Backend server ────────────────────────────────────────────────────────
HOST=127.0.0.1
PORT=8765

# ── CrewAI tracing ────────────────────────────────────────────────────────
CREWAI_TRACING_ENABLED=false
